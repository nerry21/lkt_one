# Template untuk .env.testing — test suite config (Fase 1A onwards)
#
# Setup sekali di laptop baru:
#   1. cp .env.testing.example .env.testing
#   2. php artisan key:generate --env=testing
#      (atau copy APP_KEY dari .env biar session encryption konsisten)
#   3. Bikin DB lokal:
#      CREATE DATABASE hitungan_lkt_test CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#   4. php artisan migrate --env=testing
#
# .env.testing tidak di-commit (credentials); template ini yang di-commit.
# Reference: docs/audit-findings.md bug #19 (Test Infra SQLite → MariaDB)

APP_NAME="LKT One Test"
APP_ENV=testing
APP_DEBUG=true
APP_URL=http://localhost
APP_KEY=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hitungan_lkt_test
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_LEVEL=debug
